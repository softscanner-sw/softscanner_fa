{
  "name": "@softscanner/frontend-analyzer",
  "version": "0.1.0",
  "description": "Phase 1 static extractor: derives a deterministic navigation–interaction multigraph from frontend source code.",
  "type": "module",
  "main": "./dist/models/index.js",
  "types": "./dist/models/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.src.json",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "clean": "rimraf dist",
    "a1": "tsx src/a1-cli.ts",
    "a2": "tsx src/a2-cli.ts",
    "viz": "tsx src/viz-cli.ts",
    "verify:determinism": "node scripts/verify-determinism.mjs",
    "run:all": "node scripts/run-all-subjects.mjs",
    "b0:validate": "tsx src/b0-cli.ts",
    "verify:b0-determinism": "node scripts/verify-b0-determinism.mjs",
    "b1:intents": "tsx src/b1-intent-cli.ts",
    "b1:plans": "tsx src/b1-plan-cli.ts",
    "verify:b1-determinism": "node scripts/verify-b1-determinism.mjs",
    "verify:b1-plan-determinism": "node scripts/verify-b1-plan-determinism.mjs",
    "b2:codegen": "tsx src/b2-cli.ts",
    "verify:b2-determinism": "node scripts/verify-b2-determinism.mjs",
    "logs:clean": "rimraf logs",
    "b0:wizard": "tsx src/b0-wizard-cli.ts",
    "b3": "node scripts/b3-launcher.mjs"
  },
  "keywords": [
    "static-analysis",
    "angular",
    "navigation-graph",
    "frontend",
    "AST",
    "multigraph",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@angular/compiler": "^18.0.0",
    "chromedriver": "^145.0.6",
    "selenium-webdriver": "^4.41.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/selenium-webdriver": "^4.35.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}